# Application
NODE_ENV=development
PORT=4000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=secret
DB_NAME=computer_store

# JWT
JWT_SECRET=your_super_secret_key
JWT_EXPIRES_IN=5h
JWT_REFRESH_SECRET=your_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Upload
UPLOAD_DEST=./uploads
MAX_FILE_SIZE=10485760
